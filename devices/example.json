{
  "version": "1.0",
  "device": {
    "name": "My HAven Dashboard",
    "canvas": {
      "width": 1024,
      "height": 768
    },
    "default_page": 1,
    "return_to_default": 60
  },
  "theme": {
    "colors": {
      "background": "#161C23",
      "surface": "#272E36",
      "surface2": "#363f4a",
      "primary": "#8ADF45",
      "warning": "#F0AD4E",
      "danger": "#D9534F",
      "text": "#FFFFFF",
      "text_dim": "#e6e6e6",
      "text_muted": "#9fa5ad",
      "icon_inactive": "#464c53"
    },
    "font_size": 16
  },
  "pages": [
    {
      "id": 1,
      "label": "Home",
      "widgets": [
        {
          "id": "title",
          "type": "label",
          "x": 0,
          "y": 0,
          "w": 1024,
          "h": 60,
          "text": "HAven Dashboard",
          "font_size": 28,
          "align": "center",
          "color": "primary",
          "background": "surface"
        },
        {
          "id": "clock_widget",
          "type": "clock",
          "x": 800,
          "y": 10,
          "w": 200,
          "h": 40,
          "font_size": 24,
          "color": "text",
          "background": "surface"
        },
        {
          "id": "example_button",
          "type": "button",
          "x": 40,
          "y": 100,
          "w": 180,
          "h": 120,
          "label": "Living Room",
          "icon": "[mdi:lightbulb-outline]",
          "entity": "light.living_room",
          "background": "surface",
          "icon_color": "icon_inactive",
          "label_color": "text_muted",
          "overrides": [
            {
              "when": {
                "logic": "all",
                "conditions": [{ "type": "equals", "value": "on" }]
              },
              "set": {
                "icon": "[mdi:lightbulb]",
                "icon_color": "primary",
                "label_color": "text"
              }
            }
          ],
          "action": {
            "type": "service",
            "service": "light.toggle",
            "entity_id": "light.living_room"
          }
        },
        {
          "id": "example_label",
          "type": "label",
          "x": 40,
          "y": 260,
          "w": 300,
          "h": 40,
          "entity": "sensor.temperature",
          "format": "percent",
          "prefix": "Temperature: ",
          "font_size": 18,
          "color": "text",
          "background": "surface"
        },
        {
          "id": "hint",
          "type": "label",
          "x": 40,
          "y": 680,
          "w": 944,
          "h": 30,
          "text": "Edit devices/example.json or create your own config to get started. See README.md for full documentation.",
          "font_size": 13,
          "align": "center",
          "color": "text_muted",
          "background": "background"
        }
      ]
    }
  ]
}
