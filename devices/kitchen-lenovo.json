          "w": 40,
          "font_size": 18,
          "align": "center",
          "background": "",
          "entity": "internal.connectionstatus",
          "overrides": [
            {
              "when": {
                "logic": "all",
                "conditions": [
                  {
                    "source": "state",
                    "type": "equals",
                    "value": "connected"
                  }
                ]
              },
              "set": {
                "text": "[mdi:wifi-check]",
                "color": "primary"
              }
            },
            {
              "when": {
                "logic": "all",
                "conditions": [
                  {
                    "source": "state",
                    "type": "equals",
                    "value": "connecting"
                  }
                ]
              },
              "set": {
                "text": "[mdi:wifi-sync]",
                "color": "warning"
              }
            },
            {
              "when": {
                "logic": "all",
                "conditions": [
                  {
                    "source": "state",
                    "type": "equals",
                    "value": "disconnected"
                  }
                ]
              },
              "set": {
                "text": "[mdi:wifi-remove]",
                "color": "danger"
              }
            }
          ]
        }
      ]
    },
