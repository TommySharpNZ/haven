{
    "version": "1.0",
    "device": {
        "name": "New Device Name",
        "canvas": {
            "width": 1024,
            "height": 768
        },
        "orientation": "landscape",
        "default_page": 1,
        "return_to_default": 0
    },
    "theme": {
        "colors": {
            "background": "#161C23",
            "surface": "#272E36",
            "surface2": "#363f4a",
            "primary": "#8ADF45",
            "warning": "#F0AD4E",
            "danger": "#D9534F",
            "text": "#FFFFFF",
            "text_dim": "#e6e6e6",
            "text_muted": "#9fa5ad",
            "icon_inactive": "#464c53"
        },
        "font_size": 16
    },
    "pages": [{
            "id": 1,
            "label": "Page1",
            "widgets": [{
                    "id": "example_label",
                    "type": "label",
                    "x": 0,
                    "y": 60,
                    "w": 800,
                    "h": 80,
                    "text": "WebHASP",
                    "font_size": 72,
                    "align": "center",
                    "color": "primary",
                    "background": "background"
                }, {
                    "id": "tagline",
                    "type": "label",
                    "x": 0,
                    "y": 148,
                    "w": 800,
                    "h": 36,
                    "text": "A browser-based dashboard for Home Assistant",
                    "font_size": 20,
                    "align": "center",
                    "color": "text_dim",
                    "background": "background"
                }, {
                    "id": "divider",
                    "type": "rectangle",
                    "x": 280,
                    "y": 200,
                    "w": 240,
                    "h": 2,
                    "background": "surface2",
                    "radius": 1
                }, {
                    "id": "desc1",
                    "type": "label",
                    "x": 60,
                    "y": 220,
                    "w": 680,
                    "h": 28,
                    "text": "Pixel-perfect fixed-canvas layouts driven entirely by JSON config files.",
                    "font_size": 16,
                    "align": "center",
                    "color": "text_muted",
                    "background": "background"
                }, {
                    "id": "desc2",
                    "type": "label",
                    "x": 60,
                    "y": 252,
                    "w": 680,
                    "h": 28,
                    "text": "No addons. No automations. Just drop files into your HA www folder.",
                    "font_size": 16,
                    "align": "center",
                    "color": "text_muted",
                    "background": "background"
                }, {
                    "id": "desc3",
                    "type": "label",
                    "x": 60,
                    "y": 284,
                    "w": 680,
                    "h": 28,
                    "text": "Works on tablets, iPads, smart TVs, and any device with a browser.",
                    "font_size": 16,
                    "align": "center",
                    "color": "text_muted",
                    "background": "background"
                }, {
                    "id": "nav_hint",
                    "type": "label",
                    "x": 0,
                    "y": 430,
                    "w": 800,
                    "h": 28,
                    "text": "Use the dots below to navigate between pages",
                    "font_size": 14,
                    "align": "center",
                    "color": "icon_inactive",
                    "background": "background"
                }, {
                    "id": "clock",
                    "type": "label",
                    "x": 0,
                    "y": 360,
                    "w": 800,
                    "font_size": 28,
                    "align": "center",
                    "color": "text",
                    "background": "background",
                    "entity": "internal.currentdtm",
                    "prefix": "[mdi:clock-outline]&nbsp;",
                    "format": "datetime_24"
                }
            ]
        }
    ]
}
