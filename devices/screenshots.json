{
  "version": "1.0",
  "_note": "Screenshot device for HAven documentation. Load at ?device=screenshots. Pages cycle through label widget scenarios.",
  "device": {
    "name": "Screenshots",
    "canvas": { "width": 1024, "height": 768 },
    "default_page": 1,
    "return_to_default": 0
  },
  "theme": {
    "colors": {
      "background":    "#161C23",
      "surface":       "#272E36",
      "surface2":      "#2C313B",
      "primary":       "#8ADF45",
      "warning":       "#F0AD4E",
      "danger":        "#D9534F",
      "text":          "#FFFFFF",
      "text_dim":      "#D3D3D3",
      "text_muted":    "#ADADAD",
      "icon_inactive": "#464c53"
    },
    "font_size": 16
  },
  "pages": [

    {
      "id": 0,
      "label": "Overlay",
      "_note": "Persistent overlay shown on all pages. Keeps navigation and status visible.",
      "widgets": [
        {
          "id": "p0_bar",
          "type": "rectangle",
          "x": 0, "y": 0, "w": 1024, "h": 44,
          "background": "surface2"
        },
        {
          "id": "p0_datetime",
          "type": "label",
          "entity": "internal.currentdtm",
          "format": "datetime_24",
          "x": 14, "y": 0, "w": 260, "h": 44,
          "font_size": 16,
          "align": "left",
          "valign": "center",
          "color": "text_muted"
        },
        {
          "id": "p0_device",
          "type": "label",
          "text": "HAven / Screenshots",
          "x": 280, "y": 0, "w": 464, "h": 44,
          "font_size": 16,
          "align": "center",
          "valign": "center",
          "color": "icon_inactive"
        },
        {
          "id": "p0_nav_prev",
          "type": "button",
          "x": 756, "y": 4, "w": 120, "h": 36,
          "background": "surface",
          "icon_color": "text",
          "label": "[mdi:arrow-left-thick]&nbsp;PREV",
          "label_color": "text_muted",
          "label_size": 14,
          "radius": 8,
          "action": { "type": "navigate", "direction": "prev" }
        },
        {
          "id": "p0_nav_next",
          "type": "button",
          "x": 884, "y": 4, "w": 128, "h": 36,
          "background": "surface",
          "icon_color": "text",
          "label": "NEXT&nbsp;[mdi:arrow-right-thick]",
          "label_color": "text_muted",
          "label_size": 14,
          "radius": 8,
          "action": { "type": "navigate", "direction": "next" }
        }
      ]
    },

